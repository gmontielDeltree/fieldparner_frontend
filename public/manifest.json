{
  "name": "AgrotoolsFieldPartner",
  "short_name": "Agrotools",
  "description": "Agrotools",
  "theme_color": "#f5f8fa",
  "background_color": "#FFFFFF",
  "display": "standalone",
  "scope": "./",
  "start_url": "index.html",
  "share_target": {
    "action": "index.html?shared-audio",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["audio/*"]
        }
      ]
    }
  },
  "icons": [
    {
      "src": "images/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "images/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "splash_pages": null
}
